#!/usr/bin/env bash
set -Eeuo pipefail

timestamp() { date +"%Y-%m-%dT%H:%M:%S%z"; }
log_info() { printf '[%s] [INFO] %s\n' "$(timestamp)" "$*" >&2; }
log_warn() { printf '[%s] [WARN] %s\n' "$(timestamp)" "$*" >&2; }
log_error() { printf '[%s] [ERROR] %s\n' "$(timestamp)" "$*" >&2; }

SNAPSHOT_ROOT="/mnt/moltbox-backup/snapshots"
DEBUG_SERVICE_UNIT="/etc/systemd/system/moltbox-debug-service.service"
SELF_PATH="/usr/local/bin/moltbox-snapshot"

TARGET_USER=""
TARGET_GROUP=""
TARGET_HOME=""
RUNTIME_ROOT=""
REPO_ROOT=""
MOLTBOX_DIR=""
COMPOSE_FILE=""
RUNTIME_ENV_FILE=""

usage() {
  cat >&2 <<'EOF'
Usage:
  moltbox-snapshot create
  moltbox-snapshot list
  moltbox-snapshot restore <snapshot-id>
EOF
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    log_error "moltbox-snapshot must run as root. Use sudo."
    exit 1
  fi
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    log_error "Required command not found: $1"
    exit 1
  }
}

resolve_context() {
  local invoking_user="${SUDO_USER:-${USER:-}}"
  local passwd_entry=""

  if [[ -z "${invoking_user}" ]]; then
    log_error "Unable to determine invoking user."
    exit 1
  fi

  passwd_entry="$(getent passwd "${invoking_user}" || true)"
  if [[ -z "${passwd_entry}" ]]; then
    log_error "Unable to resolve home directory for user: ${invoking_user}"
    exit 1
  fi

  TARGET_USER="${invoking_user}"
  TARGET_GROUP="$(id -gn "${invoking_user}")"
  TARGET_HOME="$(printf '%s\n' "${passwd_entry}" | cut -d: -f6)"
  RUNTIME_ROOT="${MOLTBOX_RUNTIME_ROOT:-${TARGET_HOME}/.openclaw}"
  REPO_ROOT="${MOLTBOX_REPO_ROOT:-${TARGET_HOME}/git/remram-gateway}"
  MOLTBOX_DIR="${REPO_ROOT}/moltbox"
  COMPOSE_FILE="${MOLTBOX_DIR}/config/docker-compose.yml"
  RUNTIME_ENV_FILE="${RUNTIME_ROOT}/.env"

  [[ -d "${RUNTIME_ROOT}" ]] || {
    log_error "Runtime root not found: ${RUNTIME_ROOT}"
    exit 1
  }
  [[ -d "${REPO_ROOT}" ]] || {
    log_error "Repository root not found: ${REPO_ROOT}"
    exit 1
  }
  [[ -f "${COMPOSE_FILE}" ]] || {
    log_error "Compose file not found: ${COMPOSE_FILE}"
    exit 1
  }
  [[ -f "${RUNTIME_ENV_FILE}" ]] || {
    log_error "Runtime env file not found: ${RUNTIME_ENV_FILE}"
    exit 1
  }
}

compose() {
  docker compose --env-file "${RUNTIME_ENV_FILE}" -f "${COMPOSE_FILE}" "$@"
}

capture_command() {
  local output_path="$1"
  shift
  local rc=0
  if ! "$@" >"${output_path}" 2>&1; then
    rc=$?
    printf '\ncommand_exit_code=%s\n' "${rc}" >>"${output_path}"
    log_warn "Command failed while capturing ${output_path##*/}: $*"
  fi
}

capture_file_if_exists() {
  local source_path="$1"
  local dest_path="$2"
  if [[ -f "${source_path}" ]]; then
    cp "${source_path}" "${dest_path}"
  fi
}

create_snapshot_dir() {
  mkdir -p "${SNAPSHOT_ROOT}"
  local snapshot_id=""
  local snapshot_dir=""
  while :; do
    snapshot_id="$(date +"%Y-%m-%d_%H-%M-%S")"
    snapshot_dir="${SNAPSHOT_ROOT}/${snapshot_id}"
    if mkdir "${snapshot_dir}" 2>/dev/null; then
      printf '%s\n' "${snapshot_dir}"
      return 0
    fi
    sleep 1
  done
}

stop_stack() {
  log_info "Stopping Moltbox containers."
  compose stop
}

start_stack() {
  log_info "Starting Moltbox containers."
  if compose start >/dev/null 2>&1; then
    return 0
  fi
  compose up -d
}

archive_runtime() {
  local snapshot_dir="$1"
  local runtime_parent=""
  runtime_parent="$(dirname "${RUNTIME_ROOT}")"
  tar -C "${runtime_parent}" -czf "${snapshot_dir}/runtime.tar.gz" "$(basename "${RUNTIME_ROOT}")"
}

archive_repo() {
  local snapshot_dir="$1"
  local repo_parent=""
  local repo_name=""
  repo_parent="$(dirname "${REPO_ROOT}")"
  repo_name="$(basename "${REPO_ROOT}")"

  tar \
    --exclude="${repo_name}/moltbox/debug-service/.venv" \
    --exclude="${repo_name}/moltbox/debug-service/.venv/*" \
    --exclude='__pycache__' \
    --exclude='*.pyc' \
    -C "${repo_parent}" \
    -czf "${snapshot_dir}/repo.tar.gz" \
    "${repo_name}"
}

write_metadata() {
  local snapshot_dir="$1"
  local branch=""
  local head=""

  branch="$(git -C "${REPO_ROOT}" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  head="$(git -C "${REPO_ROOT}" rev-parse HEAD 2>/dev/null || true)"

  cat >"${snapshot_dir}/metadata.json" <<EOF
{
  "created_at_utc": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "snapshot_root": "${SNAPSHOT_ROOT}",
  "snapshot_path": "${snapshot_dir}",
  "target_user": "${TARGET_USER}",
  "target_home": "${TARGET_HOME}",
  "runtime_root": "${RUNTIME_ROOT}",
  "repo_root": "${REPO_ROOT}",
  "git_branch": "${branch}",
  "git_head": "${head}"
}
EOF
}

capture_metadata() {
  local snapshot_dir="$1"

  capture_command "${snapshot_dir}/docker-ps.txt" docker ps -a
  capture_command "${snapshot_dir}/docker-images.txt" docker images
  capture_command "${snapshot_dir}/docker-volumes.txt" docker volume ls
  capture_command "${snapshot_dir}/docker-networks.txt" docker network ls
  capture_command "${snapshot_dir}/docker-compose-ps.txt" compose ps
  capture_command "${snapshot_dir}/git-status.txt" git -C "${REPO_ROOT}" status --short --branch
  capture_command "${snapshot_dir}/git-head.txt" git -C "${REPO_ROOT}" rev-parse HEAD

  capture_file_if_exists "${DEBUG_SERVICE_UNIT}" "${snapshot_dir}/moltbox-debug-service.service"
  capture_file_if_exists "${SELF_PATH}" "${snapshot_dir}/moltbox-snapshot"
}

create_snapshot() {
  local snapshot_dir=""
  local restarted=0

  snapshot_dir="$(create_snapshot_dir)"
  stop_stack

  if ! archive_runtime "${snapshot_dir}"; then
    log_error "Failed to archive runtime state."
    start_stack || true
    return 1
  fi

  if ! archive_repo "${snapshot_dir}"; then
    log_error "Failed to archive repository state."
    start_stack || true
    return 1
  fi

  write_metadata "${snapshot_dir}"
  capture_metadata "${snapshot_dir}"

  if ! start_stack; then
    log_error "Snapshot was created, but restarting the Moltbox stack failed."
    return 1
  fi
  restarted=1

  if [[ "${restarted}" -eq 1 ]]; then
    printf '%s\n' "${snapshot_dir}"
  fi
}

list_snapshots() {
  mkdir -p "${SNAPSHOT_ROOT}"
  find "${SNAPSHOT_ROOT}" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
}

restore_snapshot() {
  local snapshot_id="$1"
  local snapshot_dir="${SNAPSHOT_ROOT}/${snapshot_id}"
  local runtime_archive="${snapshot_dir}/runtime.tar.gz"
  local temp_root=""
  local extracted_runtime=""
  local backup_runtime=""

  [[ -n "${snapshot_id}" ]] || {
    log_error "Snapshot id is required."
    exit 1
  }
  [[ "${snapshot_id}" == "$(basename "${snapshot_id}")" ]] || {
    log_error "Invalid snapshot id: ${snapshot_id}"
    exit 1
  }
  [[ -d "${snapshot_dir}" ]] || {
    log_error "Snapshot directory not found: ${snapshot_dir}"
    exit 1
  }
  [[ -f "${runtime_archive}" ]] || {
    log_error "Runtime archive missing from snapshot: ${runtime_archive}"
    exit 1
  }

  temp_root="$(mktemp -d /tmp/moltbox-restore.XXXXXX)"
  backup_runtime="${RUNTIME_ROOT}.restore-backup-$(date +%s)"

  if ! tar -xzf "${runtime_archive}" -C "${temp_root}"; then
    rm -rf "${temp_root}"
    log_error "Failed to extract runtime archive."
    exit 1
  fi

  extracted_runtime="${temp_root}/$(basename "${RUNTIME_ROOT}")"
  [[ -d "${extracted_runtime}" ]] || {
    rm -rf "${temp_root}"
    log_error "Snapshot runtime payload did not contain $(basename "${RUNTIME_ROOT}")"
    exit 1
  }

  stop_stack

  if [[ -e "${RUNTIME_ROOT}" ]]; then
    mv "${RUNTIME_ROOT}" "${backup_runtime}"
  fi

  if ! mv "${extracted_runtime}" "${RUNTIME_ROOT}"; then
    log_error "Failed to place restored runtime into ${RUNTIME_ROOT}."
    rm -rf "${RUNTIME_ROOT}"
    if [[ -e "${backup_runtime}" ]]; then
      mv "${backup_runtime}" "${RUNTIME_ROOT}"
    fi
    start_stack || true
    rm -rf "${temp_root}"
    exit 1
  fi

  chown -R "${TARGET_USER}:${TARGET_GROUP}" "${RUNTIME_ROOT}"

  if ! start_stack; then
    log_error "Restored runtime failed to start; rolling back previous runtime."
    rm -rf "${RUNTIME_ROOT}"
    if [[ -e "${backup_runtime}" ]]; then
      mv "${backup_runtime}" "${RUNTIME_ROOT}"
      chown -R "${TARGET_USER}:${TARGET_GROUP}" "${RUNTIME_ROOT}"
      start_stack || true
    fi
    rm -rf "${temp_root}"
    exit 1
  fi

  rm -rf "${backup_runtime}" "${temp_root}"
  printf '%s\n' "${snapshot_dir}"
}

main() {
  local action="${1:-}"

  [[ -n "${action}" ]] || {
    usage
    exit 1
  }

  require_root
  require_cmd docker
  require_cmd tar
  require_cmd getent
  require_cmd id
  resolve_context

  case "${action}" in
    create)
      create_snapshot
      ;;
    list)
      list_snapshots
      ;;
    restore)
      restore_snapshot "${2:-}"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
