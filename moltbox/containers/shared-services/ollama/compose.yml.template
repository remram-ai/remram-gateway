services:
  ollama:
    image: "${OLLAMA_IMAGE:-moltbox-ollama:local}"
    build:
      context: .
      dockerfile: Dockerfile
      args:
        OLLAMA_BASE_IMAGE: "${OLLAMA_BASE_IMAGE:-ollama/ollama:0.6.8}"
    container_name: "{{ container_name }}"
    restart: unless-stopped
    env_file:
      - "{{ runtime_root }}/.env"
      - "{{ runtime_root }}/container.env"
    gpus: all
    volumes:
      - ollama_data:/root/.ollama
    networks:
      - moltbox_internal
    healthcheck:
      test:
        - CMD
        - ollama
        - list
      interval: 20s
      timeout: 8s
      retries: 10
      start_period: 25s

volumes:
  ollama_data:

networks:
  moltbox_internal:
    external: true
    name: "{{ internal_network_name }}"
