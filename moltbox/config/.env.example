# Moltbox Compose project identity.
COMPOSE_PROJECT_NAME=moltbox

# Only published service port (OpenClaw gateway).
GATEWAY_PORT=18789

# OpenClaw image (aligned to upstream Docker onboarding local image name).
# If using the upstream OpenClaw repo flow, this is typically built as openclaw:local.
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_GATEWAY_BIND=lan
# Set a strong random token before first LAN deployment.
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_STRONG_TOKEN

# Stable image tags (do not use :latest).
OLLAMA_IMAGE=ollama/ollama:0.6.8
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.18.0

# LAN policy baseline (used by host/network guard scripts).
LAN_CIDR=192.168.1.0/24

# OpenSearch JVM heap for single-node appliance profile.
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# Escalation governance defaults.
ESCALATION_DAILY_USD_CAP=10
ESCALATION_MAX_TOKENS=4000
ESCALATION_TIMEOUT_MS=30000

# Default cloud model IDs referenced by runtime policy.
CLOUD_REASONING_MODEL=meta-llama/Llama-4-Maverick-Instruct
DEEP_THINKING_MODEL=deepseek-ai/DeepSeek-R1
CODING_MODEL=Qwen/Qwen3-Coder-32B-Instruct
