{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:8b"
      },
      "models": {
        "ollama/qwen3:8b": {
          "alias": "Local Qwen3"
        },
        "remram-router/router": {
          "alias": "Remram Router"
        },
        "together/meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8": {
          "alias": "Maverick"
        },
        "together/Qwen/Qwen3-235B-A22B-Thinking-2507": {
          "alias": "Qwen Thinking"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "api": "ollama",
        "models": [],
        "apiKey": "ollama-local"
      },
      "remram-router": {
        "baseUrl": "http://127.0.0.1:18789/plugins/remram-runtime/router/v1",
        "api": "openai-completions",
        "models": [],
        "apiKey": "router-local"
      }
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "remram-runtime": {
        "enabled": true,
        "hooks": {
          "allowPromptInjection": true
        },
        "config": {
          "semanticRouterConfigPath": "/home/node/.openclaw/semantic-router.yaml",
          "modelRuntimePath": "/home/node/.openclaw/model-runtime.yml",
          "debugDir": "/home/node/.openclaw/semantic-router-debug",
          "responseFooter": "concise"
        }
      }
    }
  },
  "tools": {
    "deny": [
      "group:web"
    ]
  }
}
