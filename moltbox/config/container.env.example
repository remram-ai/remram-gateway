# Together API key is required for cloud escalation.
# Leave blank in VCS; set locally in container.env.
TOGETHER_API_KEY=

# Stable local model runtime image tag.
OLLAMA_IMAGE=ollama/ollama:0.6.8

# Internal service endpoints (no host exposure for these services).
OLLAMA_BASE_URL=http://ollama:11434
OPENSEARCH_URL=http://opensearch:9200

# Local routing defaults.
LOCAL_ROUTING_MODEL=qwen3:8b
CLOUD_PROVIDER=together

# Runtime behavior controls.
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000

# Signal channel polling posture (required placeholders only).
SIGNAL_ENABLED=true
SIGNAL_POLL_INTERVAL_MS=5000

# OpenSearch runtime posture.
DISCOVERY_TYPE=single-node
PLUGINS_SECURITY_DISABLED=true
